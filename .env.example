# MongoDB Connection (auto-configured in Docker Compose)
# MONGODB_URI=mongodb://mongo:27017/referralhub

# Server Configuration
PORT=5000
NODE_ENV=production

# Client Configuration
CLIENT_URL=http://localhost:3000

# JWT Secret - CHANGE THIS IN PRODUCTION
JWT_SECRET=your-super-secret-key-change-this-in-production

# Database Name
MONGO_INITDB_DATABASE=referralhub
