# ========================================
# VERCEL ENVIRONMENT VARIABLES
# ========================================
# Copy these to your Vercel Project Settings → Environment Variables
# DO NOT commit actual values to git
# ========================================

# ============ SERVER VARIABLES ============

# MongoDB Connection (REQUIRED)
# Get this from MongoDB Atlas
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/referral-hub

# JWT Secret (REQUIRED)
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-here-change-this

# Client URL (REQUIRED)
# After first deployment, update this to your actual Vercel URL
CLIENT_URL=https://your-app.vercel.app

# Node Environment
NODE_ENV=production

# ============ CLIENT VARIABLES ============

# API URL (REQUIRED)
# Use relative path for same-domain deployment
REACT_APP_API_URL=/api

# ========================================
# DEPLOYMENT CHECKLIST
# ========================================
#
# 1. Set up MongoDB Atlas:
#    - Create a cluster
#    - Create a database user
#    - Whitelist IP: 0.0.0.0/0 (all IPs for Vercel)
#    - Get connection string
#
# 2. Add all variables to Vercel:
#    - Go to: Project Settings → Environment Variables
#    - Add each variable above
#    - Select environments: Production, Preview, Development
#
# 3. First Deployment:
#    - Deploy via Vercel dashboard or CLI
#    - Note your deployment URL
#
# 4. Update CLIENT_URL:
#    - Copy your Vercel URL
#    - Update CLIENT_URL variable in Vercel
#    - Redeploy
#
# 5. Test:
#    - Visit: https://your-app.vercel.app/api/health
#    - Should return: {"status":"OK"}
#
# ========================================
